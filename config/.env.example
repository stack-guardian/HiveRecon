# Environment Configuration for HiveRecon

# AI Provider Settings
OLLAMA_BASE_URL=http://localhost:11434
AI_MODEL=qwen2.5:7b
AI_TEMPERATURE=0.3

# Database
DATABASE_URL=sqlite+aiosqlite:///data/hiverecon.db

# API Server
API_HOST=0.0.0.0
API_PORT=8080
DEBUG=false

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
API_TOKEN_EXPIRE_MINUTES=1440

# Bug Bounty Platform API Keys (optional - for scope fetching)
HACKERONE_API_TOKEN=
BUGCROWD_API_TOKEN=
INTIGRITI_API_TOKEN=

# Logging
LOG_LEVEL=INFO

# Feature Flags
ENABLE_DASHBOARD=true
ENABLE_AUDIT_LOG=true
